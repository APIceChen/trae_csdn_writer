# CSDN AI Writer - Git 忽略规则

# ====================
# Python 相关
# ====================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ====================
# 虚拟环境
# ====================
venv/
ENV/
env/
.venv/

# ====================
# IDE / 编辑器
# ====================
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# ====================
# 操作系统文件
# ====================
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# ====================
# 日志和临时文件
# ====================
*.log
*.tmp
*.temp
.cache/
logs/

# ====================
# 敏感信息（绝对不能提交！）
# ====================
.env
.env.local
.env.*.local
*.pem
*.key
secrets/
credentials/

# ====================
# 项目特定（可选忽略）
# ====================

# 📥 输入数据目录 - 排除大部分动态生成的文件
input/raw/article_*.md
input/processed/*.md

# 📤 输出产物目录 - 排除所有动态生成的内容
output/articles/*.md
output/reports/*.txt

# ✅ 保留以下关键文件（不忽略）：
# - input/raw/url_registry.md (URL 记录表)
# - fewshot_samples/ (Few-Shot 样本库)
# - templates/ (模板文件)

# 测试生成文件
tests/generated/

# Node.js（如果有前端部分）
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ====================
# 其他
# ====================
*.bak
*.backup
*.orig
